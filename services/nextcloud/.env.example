BLUEPRINT_NAME=nextcloud
RESOURCE_NAME=Nextcloud
SERVICE_SUBDOMAIN=cloud
SERVICE_CONTAINER_NAME=nextcloud
SERVICE_PORT=80

NEXTCLOUD_IMAGE=nextcloud
NEXTCLOUD_TAG=apache
POSTGRES_IMAGE=postgres
POSTGRES_TAG=17-alpine
REDIS_IMAGE=redis
REDIS_TAG=7-alpine

TZ=UTC

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=GENERATE_NEXTCLOUD_ADMIN_PASSWORD
NEXTCLOUD_TRUSTED_DOMAINS=${SERVICE_SUBDOMAIN}.${BASE_DOMAIN}
NEXTCLOUD_OVERWRITEHOST=${SERVICE_SUBDOMAIN}.${BASE_DOMAIN}
NEXTCLOUD_OVERWRITEPROTOCOL=https
NEXTCLOUD_OVERWRITECLIURL=https://${SERVICE_SUBDOMAIN}.${BASE_DOMAIN}

POSTGRES_HOST=nextcloud-database
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=GENERATE_NEXTCLOUD_DB_PASSWORD

REDIS_HOST=nextcloud-redis

# Optional resource-specific auth overrides and additions.
# Scalars override GLOBAL_AUTH_* values from the root .env.
# Indexed arrays are appended after the GLOBAL_AUTH_* arrays.
# RESOURCE_AUTH_PINCODE=
# RESOURCE_AUTH_PASSWORD=
# RESOURCE_AUTH_BASIC_USER=
# RESOURCE_AUTH_BASIC_PASSWORD=
# RESOURCE_AUTH_SSO_ENABLED=
# RESOURCE_AUTH_SSO_ROLE_0=
# RESOURCE_AUTH_SSO_USER_0=
# RESOURCE_AUTH_WHITELIST_USER_0=
