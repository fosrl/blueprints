BLUEPRINT_NAME=paperless-ngx
RESOURCE_NAME=Paperless-ngx
SERVICE_SUBDOMAIN=paperless
SERVICE_CONTAINER_NAME=paperless-webserver
SERVICE_PORT=8000

# Image tags
PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx
PAPERLESS_TAG=latest
REDIS_IMAGE=docker.io/library/redis
REDIS_TAG=8
POSTGRES_IMAGE=docker.io/library/postgres
POSTGRES_TAG=17

# Paperless app settings
PAPERLESS_TIME_ZONE=UTC
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_SECRET_KEY=GENERATE_PAPERLESS_SECRET_KEY
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=GENERATE_PAPERLESS_ADMIN_PASSWORD

# Redis connection used by paperless-webserver
PAPERLESS_REDIS=redis://paperless-redis:6379

# Postgres connection used by paperless-webserver
PAPERLESS_DBENGINE=postgresql
PAPERLESS_DBHOST=paperless-database
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=GENERATE_PAPERLESS_DB_PASSWORD

# Postgres container init values
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=GENERATE_PAPERLESS_DB_PASSWORD

# Optional resource-specific auth overrides and additions.
# RESOURCE_AUTH_SSO_ROLE_0=Admin
# RESOURCE_AUTH_WHITELIST_USER_0=admin@example.com
