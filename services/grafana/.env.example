BLUEPRINT_NAME=grafana
RESOURCE_NAME=Grafana
SERVICE_SUBDOMAIN=grafana
SERVICE_CONTAINER_NAME=grafana
SERVICE_PORT=3000

GRAFANA_IMAGE=grafana/grafana
GRAFANA_TAG=latest
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=GENERATE_GRAFANA_ADMIN_PASSWORD
GF_SERVER_ROOT_URL=https://${SERVICE_SUBDOMAIN}.${BASE_DOMAIN}
GF_SERVER_DOMAIN=${SERVICE_SUBDOMAIN}.${BASE_DOMAIN}
GF_USERS_ALLOW_SIGN_UP=false
GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/newt-overview.json

# Optional resource-specific auth overrides and additions.
# Scalars override GLOBAL_AUTH_* values from the root .env.
# Indexed arrays are appended after the GLOBAL_AUTH_* arrays.
# RESOURCE_AUTH_PINCODE=
# RESOURCE_AUTH_PASSWORD=
# RESOURCE_AUTH_BASIC_USER=
# RESOURCE_AUTH_BASIC_PASSWORD=
# RESOURCE_AUTH_SSO_ENABLED=
# RESOURCE_AUTH_SSO_ROLE_0=
# RESOURCE_AUTH_SSO_USER_0=
# RESOURCE_AUTH_WHITELIST_USER_0=
