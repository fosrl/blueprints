# Shared DNS root used by all blueprints.
BASE_DOMAIN=CHANGE_ME

# Shared Docker network that Newt and public-facing blueprint containers join.
PANGOLIN_DOCKER_NETWORK=pangolin_default

# Host-side container engine socket to mount into Newt.
# Docker default: /var/run/docker.sock
# Rootless Podman example: /run/user/1000/podman/podman.sock
HOST_CONTAINER_SOCKET=/var/run/docker.sock

# Newt configuration from Pangolin.
PANGOLIN_ENDPOINT=https://app.pangolin.net
NEWT_ID=CHANGE_ME
NEWT_SECRET=CHANGE_ME

# Optional overrides.
NEWT_IMAGE=fosrl/newt:latest
NEWT_CONTAINER_NAME=newt

# Optional global auth defaults applied to all blueprint resources.
# Services can override or extend these with RESOURCE_AUTH_* entries
# in their own services/<name>/.env file.
GLOBAL_AUTH_PINCODE=
GLOBAL_AUTH_PASSWORD=
GLOBAL_AUTH_BASIC_USER=
GLOBAL_AUTH_BASIC_PASSWORD=
GLOBAL_AUTH_SSO_ENABLED=
GLOBAL_AUTH_SSO_ROLE_0=
GLOBAL_AUTH_SSO_ROLE_1=
GLOBAL_AUTH_SSO_USER_0=
GLOBAL_AUTH_SSO_USER_1=
GLOBAL_AUTH_WHITELIST_USER_0=
GLOBAL_AUTH_WHITELIST_USER_1=
